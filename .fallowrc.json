{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/config.schema.json",
  "entry": [
    "src/renderer/src/main.tsx",
    "src/renderer/index.html"
  ],
  "ignorePatterns": [
    "vite.config.js",
    "vite.config.d.ts",
    ".fallow/**",
    "dist/**",
    "playwright-report/**",
    "test-results/**",
    "src/state/libraryStore.ts",
    "src/state/projectStore.ts",
    "src/state/selectors.ts"
  ],
  "ignoreDependencies": ["zundo", "playwright-core", "v8-to-istanbul"],
  "usedClassMembers": [
    "initProject", "trackCount", "hasClipboardPattern", "play", "pause",
    "stop", "setBpm", "backToStart", "goToEnd", "setLoopEnabled",
    "toggleLoop", "toggleStep", "toggleMute", "toggleSolo", "setTrackPan",
    "setTrackGain", "clearPattern", "copyPattern", "copyStepRange",
    "copyPatternToClipboard", "pastePatternFromClipboard", "undo", "redo",
    "addTrack", "removeTrack", "listInputSamples", "listTestSamples",
    "assignSample", "assignTestSample", "assignFromBrowser", "previewSample",
    "onScheduleTick", "dispose"
  ],
  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "error",
    "unused-dependencies": "error",
    "unused-dev-dependencies": "error",
    "unlisted-dependencies": "error"
  }
}
