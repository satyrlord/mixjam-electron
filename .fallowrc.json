{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/renderer/src/main.tsx",
    "src/renderer/index.html",
    // AudioWorklet processors are real runtime roots: they are pulled in with
    // Vite's `?worker&url`, which yields a URL string rather than a module-graph
    // edge, so everything they reach (the Master Bus DSP chain and its modules)
    // is invisible to static analysis unless they are declared here.
    "src/renderer/src/engine/worklets/master-bus.worklet.ts",
    "src/renderer/src/engine/worklets/echoform-delay.worklet.ts",
    "src/renderer/src/engine/worklets/loudness.worklet.js"
  ],
  "ignorePatterns": [
    ".fallow/**",
    "dist/**",
    "playwright-report/**",
    "test-results/**"
  ],
  "ignoreDependencies": ["playwright-core", "v8-to-istanbul"],
  // Members reached through an interface or a facade, which the static
  // "referenced outside its class" check cannot resolve. Each name below has
  // verified call sites; none is dead code.
  "usedClassMembers": [
    "play", "pause", "stop", "setBpm", "previewSample", "undo", "redo",
    "applyReturnSnapshot", "getMasterBusMeterSnapshot", "setMasterBusMetersActive",
    // The BusModule contract (masterbus/dsp/module.ts), implemented by all
    // Master Bus processors and invoked polymorphically by the DSP chain.
    {
      "implements": "BusModule",
      "members": ["id", "latencySamples", "updateParams", "process", "reset", "grDb"]
    },
    // Concrete saturators inherit the BusModule contract through their shared
    // abstract base, so their declared members need the same narrow heritage scope.
    {
      "extends": "OversampledSaturator",
      "members": ["id", "updateParams"]
    },
    // These internal contracts keep common DSP member names scoped to the
    // exact polymorphic surfaces that Fallow cannot resolve across the worklet.
    {
      "implements": "DownstreamChain",
      "members": [
        "setTopology", "topologyEquals", "isPowered", "latencySamples",
        "updateParams", "process", "reset"
      ]
    },
    {
      "implements": "BlockSmoother",
      "members": ["pending", "advance"]
    },
    {
      "implements": "IdentityFilter",
      "members": ["identity"]
    }
  ],
  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "error",
    "unused-dependencies": "error",
    "unused-dev-dependencies": "error",
    "unlisted-dependencies": "error"
  }
}
