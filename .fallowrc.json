{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/renderer/src/main.tsx",
    "src/renderer/index.html"
  ],
  "ignorePatterns": [
    ".fallow/**",
    "dist/**",
    "playwright-report/**",
    "test-results/**"
  ],
  "ignoreDependencies": ["playwright-core", "v8-to-istanbul"],
  "usedClassMembers": [
    "play", "pause", "stop", "setBpm", "previewSample", "undo", "redo",
    "getChannelEffectReduction", "applyReturnSnapshot"
  ],
  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "error",
    "unused-dependencies": "error",
    "unused-dev-dependencies": "error",
    "unlisted-dependencies": "error"
  }
}
