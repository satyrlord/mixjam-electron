{
  "pkg": "mixjam-electron",
  "globalName": "MixJam",
  "projectId": "7a1e081e-36c0-48b5-a3d4-39a80a551689",
  "shape": "package",
  "srcDir": "src/renderer/src/components",
  "tsconfig": "tsconfig.web.json",
  "cssEntry": ".design-sync/design-sync-styles.css",
  "extraFonts": [
    "src/renderer/public/fonts/JosefinSans-Regular.ttf",
    "src/renderer/public/fonts/JosefinSans-Bold.ttf",
    "src/renderer/public/fonts/Ubuntu-Regular.ttf",
    "src/renderer/public/fonts/Ubuntu-Medium.ttf",
    "src/renderer/public/fonts/JetBrainsMono-Regular.ttf",
    "src/renderer/public/fonts/JetBrainsMono-Medium.ttf",
    "src/renderer/public/fonts/SpecialElite-Regular.ttf"
  ],
  "libOverrides": {
    "source-kit.mjs": "(1) all components use export default; the stock synth-entry writer's `export * from` never re-exports defaults, leaving window.MixJam empty ([BUNDLE_EXPORT]) — fork writes named re-exports instead. (2) also pulls in the design-sync-only AppShell harness (.design-sync/app-shell.tsx, outside srcDir) as a first-class discovered component — see EXTRA_COMPONENT_FILES in the fork."
  },
  "guidelinesGlob": [],
  "docsMap": {
    "AppShell": ".design-sync/docs/AppShell.md"
  },
  "readmeHeader": ".design-sync/conventions.md",
  "extraEntries": ["./.design-sync/theme-bootstrap.tsx"],
  "provider": {
    "component": "ThemeBootstrap"
  },
  "overrides": {
    "ManagePanel": { "cardMode": "column" },
    "TrackerView": { "cardMode": "column" },
    "Header": { "cardMode": "column" },
    "LaneClipCanvas": { "cardMode": "column" },
    "Footer": { "cardMode": "column" },
    "AppShell": { "cardMode": "column" },
    "ScanOverlay": { "cardMode": "single", "primaryStory": "Scanning" }
  },
  "buildCmd": "node .design-sync/generate-theme-tokens.mjs && node .ds-sync/package-build.mjs --config .design-sync/config.json --node-modules ./node_modules --entry ./out/main/does-not-exist.js --out ./ds-bundle"
}
