{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mixjam.dev/schemas/generator-template-v1.json",
  "title": "MixJam generator template",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "label",
    "version",
    "bpmTolerance",
    "coreLanes",
    "sections",
    "lanes"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "maxLength": 64, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "label": { "type": "string", "minLength": 1, "maxLength": 64 },
    "version": { "type": "integer", "minimum": 1 },
    "order": { "type": "integer", "minimum": 0 },
    "default": { "type": "boolean" },
    "bpmTolerance": { "type": "number", "minimum": 0, "maximum": 60 },
    "coreLanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/laneIndex" }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    },
    "lanes": {
      "type": "array",
      "minItems": 16,
      "maxItems": 16,
      "items": { "$ref": "#/$defs/lane" }
    }
  },
  "$defs": {
    "laneIndex": { "type": "integer", "minimum": 0, "maximum": 15 },
    "beatOffsets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "integer", "minimum": 0, "maximum": 31 }
    },
    "sampleType": {
      "enum": ["Kick", "Snare", "Hi-hat", "Percussion", "Bass", "Synth", "FX", "Vocal", "Loop", "Atmosphere", "Other"]
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "weight", "activeLanes", "phraseMode"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "weight": { "type": "integer", "minimum": 1, "maximum": 100 },
        "activeLanes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/laneIndex" }
        },
        "phraseMode": { "enum": ["sparse", "steady", "build", "breakdown", "return", "peak", "outro"] }
      }
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "types", "maxBars", "role", "gain", "pan"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sampleType" }
        },
        "maxBars": { "type": "integer", "minimum": 1, "maximum": 999 },
        "maxBeats": { "type": "integer", "minimum": 1, "maximum": 4 },
        "role": { "enum": ["percussion", "motif", "vocal", "atmosphere", "transition"] },
        "beatPattern": { "$ref": "#/$defs/beatOffsets" },
        "beatMutation": { "$ref": "#/$defs/beatOffsets" },
        "intentionalAnchor": { "type": "boolean" },
        "preferLong": { "type": "boolean" },
        "transitionKind": { "enum": ["riser", "impact"] },
        "gain": { "type": "number", "minimum": 0, "maximum": 1 },
        "pan": { "type": "number", "minimum": -1, "maximum": 1 }
      }
    }
  },
  "$comment": "The runtime parser also enforces filename/id equality, unique names, section weights totaling 100, full lane activation, role-specific fields, and registry-wide ID/default uniqueness."
}
