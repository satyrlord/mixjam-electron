{
  "name": "mixjam-electron",
  "version": "0.43",
  "description": "MixJam Electron — sample-library browser and tracker",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "fallow": "fallow dead-code",
    "package:electron": "electron-builder --config electron-builder.config.cjs --publish never",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && npx playwright test --project=browser-e2e",
    "test:e2e:coverage": "npm run test:e2e && node scripts/convert-e2e-coverage.mjs",
    "test:e2e:electron": "npm run build && npx playwright test --project=electron-smoke",
    "test:all": "npm run test && npm run test:e2e",
    "coverage:all": "npm run test:coverage && npm run test:e2e:coverage",
    "coverage:report": "node scripts/merge-coverage.mjs",
    "generate:mixer-test-song": "tsx scripts/generate-mixer-test-song.ts",
    "measure:analysis-corpus": "tsx scripts/measure-analysis-corpus.ts",
    "measure:song-progress-performance": "npm run build && node scripts/measure-song-progress-performance.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^42.5.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fallow": "^2.103.0",
    "globals": "^17.7.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.61.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.62.0",
    "tsx": "^4.20.6",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^7.1.12",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "@tanstack/react-virtual": "^3.14.5",
    "loudness-worklet": "1.6.9",
    "music-metadata": "^11.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.12.1"
  },
  "allowScripts": {
    "electron@42.5.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "electron-winstaller@5.4.0": true
  }
}
